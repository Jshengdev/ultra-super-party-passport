# Neo4j Aura (from the credentials .txt downloaded at instance creation)
NEO4J_URI=neo4j+s://<id>.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
# Butterbase (dashboard.butterbase.ai -> API Keys; gateway is OpenAI-compatible)
BUTTERBASE_API_KEY=bb_sk_...
BUTTERBASE_GATEWAY_URL=https://api.butterbase.ai/v1
# RocketRide Cloud (cloud.rocketride.ai)
ROCKETRIDE_URI=https://api.rocketride.ai
ROCKETRIDE_APIKEY=
